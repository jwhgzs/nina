// 这里会讲解Nina中的对象
// 注：Nina中的数组、通用对象统称“对象”！~

// 数组的定义
var arr = array (
    2, 4, 7, 8, 12, 13, 15, 16
);

// 通用对象的定义。瞧瞧这奇妙的内联语法：
var obj = object {
    // 直接在这进行内联初始化
    // 语法和外边的一样呢！~
    var a = 1;
    var b = 2;
    func c() {
        console_printf('hell, world');
    }
    // 另外也能像外面一样定义常量哦！超酷的！
    const pi = 3.14;
};

// 对象的成员访问。
// Nina中可用 [ 和 . 两个成员访问符，其中 . 为 [ 的简写语法糖：
var mem1 = arr[2];
const mem2 = obj.pi;
const mem3 = obj['p' + 'i'];